#ifndef SECRETS_H
#define SECRETS_H

// ----------------------------------------------------------------------------
// Local secrets / preconfigured WiFi credentials
//
// 1. Copy this file to "secrets.h" (in the same folder).
// 2. Fill in your own WiFi credentials below.
//
// "secrets.h" is listed in .gitignore so your real credentials are NEVER
// committed to the repository. If you don't want to bake credentials into the
// firmware at all, leave the placeholders as-is: the preconfigured connection
// will simply fail and the device falls back to the WiFiManager captive portal
// (SSID "esp32Project", password "12345678").
// ----------------------------------------------------------------------------

#define PRECONFIGURED_SSID "YOUR_WIFI_SSID"
#define PRECONFIGURED_PASSWORD "YOUR_WIFI_PASSWORD"
#define PRECONFIGURED_TIMEZONE "America/New_York"

// Optional password for over-the-air (OTA) firmware updates. With the empty
// default, any machine on your WiFi can flash the device; set a password to
// require authentication (PlatformIO then needs: upload_flags = --auth=<pw>).
// The same credentials protect the web settings page (username "admin").
#define OTA_PASSWORD ""

// Optional: override where the weekly market-holiday calendar refresh is
// fetched from (defaults to marketHolidays.json in the project's GitHub
// repository - see marketHolidays.cpp). Point this at your own copy if you
// fork the repo or want to self-host the file.
// #define MARKET_HOLIDAYS_URL "https://example.com/marketHolidays.json"

#endif // SECRETS_H
